# Google Sheets ──────────────────────────────────────────────────────────────
# Path to a service-account JSON file with the Sheets API enabled and the
# target spreadsheet shared with the service-account email.
GOOGLE_CREDENTIALS_JSON_PATH=./credentials.json

# Spreadsheet ID — the long token between /d/ and /edit in the sheet URL.
SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789AbCd

# REST API ───────────────────────────────────────────────────────────────────
# Base URL of your CRM / database / app. The api_resource from config.yaml
# is appended (e.g. https://api.example.com/v1 + customers).
API_BASE_URL=https://api.example.com/v1

# Bearer token. Leave blank for unauthenticated APIs.
API_TOKEN=

# Sync behavior ──────────────────────────────────────────────────────────────
# One of: last_write_wins | sheet_wins | api_wins | manual
# (Overridden by conflict_strategy in config.yaml if set there.)
CONFLICT_STRATEGY=last_write_wins

# Default loop interval if you run `sync.py sync --loop $SYNC_INTERVAL_SECONDS`.
SYNC_INTERVAL_SECONDS=600

# Where to keep the audit log.
AUDIT_DB_PATH=./audit.db
